{
	// Window
	"window.commandCenter": true,
	"window.titleBarStyle": "custom",
	// Files
	"files.exclude": {
		"**/.classpath": true,
		"**/.project": true,
		"**/.settings": true,
		"**/.factorypath": true,
	},
	"files.associations": {
		"**/*.html": "html",
		"**/templates/**/*.html": "django-html",
		"**/templates/**/*.txt": "django-txt",
		"**/requirements{/**,*}.{txt,in}": "pip-requirements",
		"*.css": "css",
		".env": "dotenv",
		"*.com": "nginx",
		".env*": "dotenv"
	},
	"files.watcherExclude": {
		"**/.git/objects/**": true,
		"**/.git/subtree-cache/**": true,
		"**/node_modules/*/**": true,
	},
	"material-icon-theme.files.associations": {
		"vitest.config.e2e.ts": "vitest",
		"jest.config.integration.ts": "jest",
	},
	// Emmet
	"emmet.includeLanguages": {
		"django-html": "html",
		"django-template": "html",
	},
	// Terminal
	"terminal.integrated.defaultProfile.windows": "Windows PowerShell",
	"terminal.integrated.profiles.windows": {
		"Windows PowerShell": {
			"source": "PowerShell",
			"icon": "terminal-powershell",
			"path": "C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
		},
		"Command Prompt": {
			"path": [
				"${env:windir}\\Sysnative\\cmd.exe",
				"${env:windir}\\System32\\cmd.exe",
			],
			"args": [],
			"icon": "terminal-cmd",
		},
		"Git Bash": {
			"source": "Git Bash",
		},
	},
	"terminal.integrated.defaultProfile.linux": "zsh",
	"terminal.integrated.profiles.linux": {
		"bash": {
			"path": "bash",
			"icon": "terminal-bash",
		},
		"zsh": {
			"path": "/usr/bin/zsh",
		},
		"tmux": {
			"path": "tmux",
			"icon": "terminal-tmux",
		},
	},
	"terminal.integrated.fontFamily": "FiraCode Nerd Font Propo, Hack Nerd Font Mono, monospace",
	"terminal.integrated.fontLigatures.enabled": true,
	// Editor
	"editor.suggestSelection": "first",
	"editor.fontFamily": "FiraCode Nerd Font, Hack Nerd Font, monospace",
	"editor.fontLigatures": true,
	"editor.linkedEditing": true,
	"editor.wordWrap": "bounded",
	"editor.wordWrapColumn": 120,
	"editor.wrappingIndent": "same",
	"editor.stickyScroll.enabled": true,
	"editor.acceptSuggestionOnEnter": "off",
	"editor.cursorSmoothCaretAnimation": "on",
	"editor.cursorBlinking": "smooth",
	"editor.smoothScrolling": true,
	"editor.largeFileOptimizations": false,
	"editor.minimap.renderCharacters": false,
	"editor.lineNumbers": "relative",
	"editor.insertSpaces": true,
	"editor.renderLineHighlight": "gutter",
	"editor.tokenColorCustomizations": {
		"[*Light*]": {
			"textMateRules": [
				{
					"scope": "ref.matchtext",
					"settings": {
						"foreground": "#000"
					}
				}
			]
		},
		"[*Dark*]": {
			"textMateRules": [
				{
					"scope": "ref.matchtext",
					"settings": {
						"foreground": "#fff"
					}
				}
			]
		},
		"textMateRules": []
	},
	"[python]": {
		"editor.defaultFormatter": "charliermarsh.ruff",
		"editor.formatOnSave": true,
		"editor.codeActionsOnSave": {
			"source.organizeImports": "explicit",
			"source.fixAll": "always",
		},
		"editor.tabSize": 4,
	},
	"[vue][html][javascript][typescript][scss][css][json][javascriptreact][typescriptreact][jsonc][yaml]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.tabSize": 2,
		"editor.insertSpaces": true,
	},
	"[haskell]": {
		"editor.tabSize": 2,
	},
	"[django-html]": {
		"editor.quickSuggestions": {
			"other": true,
			"comments": true,
			"strings": true,
		},
		"editor.tabSize": 4,
		"editor.defaultFormatter": "monosans.djlint",
		"editor.codeActionsOnSave": {
			"source.fixAll": "always",
		},
	},
	"[java]": {
		"editor.defaultFormatter": "redhat.java",
	},
	"[prisma]": {
		"editor.defaultFormatter": "Prisma.prisma",
		"editor.formatOnSave": true,
		"editor.codeActionsOnSave": {
			"source.fixAll": "always",
		},
	},
	"[dotenv]": {
		"editor.defaultFormatter": "dotenv.dotenv-vscode",
		"editor.formatOnSave": true,
		"editor.codeActionsOnSave": {
			"source.fixAll": "always",
		},
	},
	"cSpell.language": "en,pt,pt_BR",
	// HTML
	"html.format.indentInnerHtml": true,
	"html.format.extraLiners": "",
	"html.format.templating": true,
	// Python
	"python.testing.pytestEnabled": true,
	"python.pyrefly.disableLanguageServices": true,
	// Prettier
	"prettier.arrowParens": "avoid",
	"prettier.singleQuote": true,
	"prettier.useTabs": true,
	// Workbench
	"workbench.sideBar.location": "right",
	"workbench.iconTheme": "material-icon-theme",
	// Vim
	"vim.useCtrlKeys": false,
	"vim.insertModeKeyBindings": [
		{
			"before": ["k", "j"],
			"after": ["<Esc>"],
		},
	],
	"vim.useSystemClipboard": true,
	"vim.easymotion": true,
	"vim.leader": " ",
	"vim.smartRelativeLine": true,
	// Git
	"git.autofetch": true,
	"git.confirmSync": false,
	// Icons
	"material-icon-theme.activeIconPack": "nest",
	// Markdown
	"markdownlint.config": {
		"MD033": false,
		"MD041": false,
	},
	// Explorer
	"explorer.confirmDelete": false,
	// TypeScript
	"typescript.updateImportsOnFileMove.enabled": "always",
	// GitHub
	"github.copilot.nextEditSuggestions.enabled": true,
	// Mise
	"mise.configureExtensionsAutomatically": false,
	// Docker
	"docker.extension.enableComposeLanguageServer": false,
	// Spell Checker
	"cSpell.enabledSchemes": {
		"comment": true,
		"file": true,
		"gist": true,
		"repo": true,
		"sftp": true,
		"untitled": true,
		"vscode-notebook-cell": true,
		"vscode-scm": true,
		"vscode-userdata": true,
		"vscode-vfs": true,
		"vsls": true,
		"overleaf-workshop": true
	},
	// Micellaneous
	"mise.binPath": "/home/william/.local/bin/mise",
	"dotenv.enableAutocloaking": false,
	"security.workspace.trust.untrustedFiles": "open",
	"explorer.confirmDragAndDrop": false,
	"chat.tools.terminal.autoApprove": {
		"gh": true,
		"sed": true,
		"uv": true,
		"make": true,
	},
	"gitlens.ai.model": "vscode",
	"gitlens.ai.vscode.model": "copilot:gpt-4.1",
	"diffEditor.codeLens": true,
	"chat.mcp.gallery.enabled": true,
	"json.schemaDownload.trustedDomains": {
		"https://schemastore.azurewebsites.net/": true,
		"https://raw.githubusercontent.com/": true,
		"https://www.schemastore.org/": true,
		"https://json.schemastore.org/": true,
		"https://json-schema.org/": true,
		"https://biomejs.dev": true,
	},
	"claudeCode.preferredLocation": "panel",
	"chat.editing.confirmEditRequestRemoval": false,
	"python.languageServer": "Default",
}
